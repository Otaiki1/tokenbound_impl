# =============================================================================
# CrowdPass Tokenbound — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Never commit .env.local or any file containing real secrets.
#
# For network-specific setups, see:
#   .env.testnet.example  — pre-filled testnet defaults
#   .env.mainnet.example  — mainnet values (requires real contract addresses)
# =============================================================================

# App
NEXT_PUBLIC_BASE_URL=https://crowdpass.io

# Stellar / Soroban Network
# Testnet: https://horizon-testnet.stellar.org
# Mainnet: https://horizon.stellar.org
# For high availability, you can specify multiple URLs separated by commas
# The system will automatically failover to healthy endpoints
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org,https://horizon-testnet-2.stellar.org

# Testnet: https://soroban-testnet.stellar.org
# For high availability, you can specify multiple URLs separated by commas
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org,https://soroban-testnet-2.stellar.org

# Testnet:  Test SDF Network ; September 2015
# Mainnet:  Public Global Stellar Network ; September 2015
NEXT_PUBLIC_NETWORK_PASSPHRASE=

# Contract Addresses
NEXT_PUBLIC_EVENT_MANAGER_CONTRACT=
NEXT_PUBLIC_MARKETPLACE_CONTRACT=
